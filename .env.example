APP_NAME=discourse-assignee-automation
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8080
DRY_RUN=true

DISCOURSE_BASE_URL=https://support.wirenboard.com
DISCOURSE_API_KEY=replace_me
DISCOURSE_API_USERNAME=system

SEARCH_AFTER_DATE=2023-11-01

POLL_INTERVAL_SECONDS=300
BATCH_SIZE=75
HISTORY_RETENTION_DAYS=180

SQLITE_PATH=/data/state.db

HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=5
HTTP_RETRY_BACKOFF_BASE=1
HTTP_RETRY_BACKOFF_MAX=20

ASSIGN_UNASSIGN_ENDPOINT=/assign/unassign
ASSIGN_ASSIGN_ENDPOINT=/assign/assign
ASSIGN_PAYLOAD_TOPIC_KEY=topic_id
ASSIGN_PAYLOAD_USER_KEY=username
ASSIGN_USE_USER_ID=false

HEALTHCHECK_ENABLE_EXPLORER_RUN=false
